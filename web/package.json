{
  "name": "foca-web",
  "version": "1.0.0",
  "private": true,
  "description": "FOCA Web - Serverless document metadata analyzer on Cloudflare",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "vite build && wrangler deploy --dry-run",
    "build:frontend": "vite build",
    "deploy": "vite build && wrangler deploy",
    "preview": "wrangler dev --local",
    "db:init": "wrangler d1 execute foca-db --local --file=./migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute foca-db --remote --file=./migrations/0001_init.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "jszip": "^3.10.1",
    "pdf-parse": "^1.1.1",
    "exifr": "^7.1.3",
    "cfb": "^1.2.2",
    "fast-xml-parser": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.0",
    "wrangler": "^3.57.0"
  }
}
